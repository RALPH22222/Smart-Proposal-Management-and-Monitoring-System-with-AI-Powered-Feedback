# ---------------------------------------------------------------------------
# SPMAMS e2e environment
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values before running tests.
# NEVER commit the filled `.env` (it is already gitignored).
# ---------------------------------------------------------------------------

# Base URL of the frontend under test. Leave unset to use the auto-started
# local Vite dev server at http://localhost:5173.
# BASE_URL=https://wmsu-rdec.com

# Supabase project (used by scripts/seed-accounts.ts only — NOT by the tests
# themselves, which drive the browser like a real user).
SUPABASE_URL=https://ilutdlvlhjpxsyvedyxf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_ANON_KEY=replace-with-anon-key

# Fixture account credentials — one per role. The seed script uses these
# exact email+password pairs; if you change them here, re-run the seed.
FIXTURE_PASSWORD=E2eTest!Password2026

FIXTURE_PROPONENT_EMAIL=e2e.proponent@wmsu-test.local
FIXTURE_RND_EMAIL=e2e.rnd@wmsu-test.local
FIXTURE_EVALUATOR_EMAIL=e2e.evaluator@wmsu-test.local
FIXTURE_ADMIN_EMAIL=e2e.admin@wmsu-test.local

# Department ID to assign seed accounts to. Any existing department ID
# from the `departments` table works; the seed script will fall back to the
# first available department if this is empty.
FIXTURE_DEPARTMENT_ID=
